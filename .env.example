# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (e-mails)
RESEND_API_KEY=re_...

# App URL
NEXT_PUBLIC_APP_URL=https://voku.one

# Meta / Instagram (edge functions secrets)
# META_PAGE_ACCESS_TOKEN=...
# META_PAGE_ID=...
# META_INSTAGRAM_ACCOUNT_ID=...

# Image Generation — Ideogram 3.0 (tipográfico, split-layout)
IDEOGRAM_API_KEY=your-ideogram-api-key

# Image Generation — ImagineArt (produto em cena, ambiental, multi-tela)
IMAGINEART_API_KEY=your-imagineart-api-key

# Image Generation — fal.ai FLUX.2 (tela em destaque, foto com texto)
FAL_KEY=your-fal-ai-key
